# ============================================================
# Claude Assistant Bridge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your secrets.
# ============================================================

# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id_here

# ------------------------------------------------------------
# Cloudflare Tunnel
# ------------------------------------------------------------
# Fallback URL if auto-detection fails (usually not needed)
# This is populated automatically by the webhook server
CLOUDFLARE_TUNNEL_URL=https://your-tunnel-name.trycloudflare.com

# ------------------------------------------------------------
# Local Server
# ------------------------------------------------------------
WEBHOOK_PORT=8080

# ------------------------------------------------------------
# File Paths (use forward slashes on Windows)
# ------------------------------------------------------------
TASKS_FILE=C:/AIAssistant/tasks.json
RUN_LOG_FILE=C:/AIAssistant/run_log.jsonl
LOGS_DIR=C:/AIAssistant/logs

# ------------------------------------------------------------
# Identity (passed to Claude Code as context)
# ------------------------------------------------------------
USER_DISPLAY_NAME=YourFirstName
TIMEZONE=America/New_York
